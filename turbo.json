{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": ["tsconfig.json"],
  "globalEnv": [
    "NODE_ENV",
    "ADMIN_TEST_NUMBER",
    "API_URL",
    "APP_URL",
    "BACKEND_URL",
    "BRAVE_SEARCH_API_KEY",
    "CALL_RUNTIME_PROVIDER",
    "CORS_ORIGIN",
    "DEMO_MODE",
    "DEV_USER_EMAIL",
    "DEV_USER_ID",
    "DEV_USER_NAME",
    "GEMINI_API_KEY",
    "GOOGLE_API_KEY",
    "GOOGLE_PLACES_API_KEY",
    "KESTRA_API_TOKEN",
    "KESTRA_CLOUD_TENANT",
    "KESTRA_CLOUD_URL",
    "KESTRA_ENABLED",
    "KESTRA_HEALTH_CHECK_TIMEOUT",
    "KESTRA_LOCAL_PASSWORD",
    "KESTRA_LOCAL_URL",
    "KESTRA_LOCAL_USERNAME",
    "KESTRA_MODE",
    "KESTRA_NAMESPACE",
    "KESTRA_URL",
    "LIVE_CALL_ENABLED",
    "LIVEKIT_AGENT_NAME",
    "LIVEKIT_API_KEY",
    "LIVEKIT_API_SECRET",
    "LIVEKIT_SIP_FROM_NUMBER",
    "LIVEKIT_SIP_KRISP_ENABLED",
    "LIVEKIT_SIP_OUTBOUND_TRUNK_ID",
    "LIVEKIT_URL",
    "NEXT_PUBLIC_GOOGLE_PLACES_API_KEY",
    "PORT",
    "REQUIRE_AUTH",
    "STRIPE_PRICE_PRO",
    "STRIPE_PRICE_STARTER",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "SUPABASE_JWT_SECRET",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_URL",
    "TWILIO_ACCOUNT_SID",
    "TWILIO_AUTH_TOKEN",
    "TWILIO_PHONE_NO",
    "TWILIO_PHONE_NUMBER",
    "VAPI_ADVANCED_SCREENING",
    "VAPI_API_KEY",
    "VAPI_PHONE_NUMBER_ID",
    "VAPI_REALTIME_VOICE",
    "VAPI_USE_REALTIME",
    "VAPI_WEBHOOK_URL",
    "VOICE_AGENT_API_BASE_URL",
    "VOICE_AGENT_HOST",
    "VOICE_AGENT_PORT",
    "VOICE_AGENT_RECORDINGS_DIR",
    "VOICE_AGENT_SERVICE_URL",
    "VOICE_AGENT_SHARED_SECRET",
    "VOICE_AGENT_WORKER_CONTROL_PORT",
    "VOICE_AGENT_WORKER_CONTROL_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"]
    }
  }
}
