VOICE_AGENT_HOST=0.0.0.0
VOICE_AGENT_PORT=8787
VOICE_AGENT_WORKER_CONTROL_PORT=8788
CALL_RUNTIME_PROVIDER=livekit
VOICE_AGENT_API_BASE_URL=http://127.0.0.1:8000/api/v1/voice-tools
VOICE_AGENT_SHARED_SECRET=replace-with-the-same-secret-used-by-apps-api
VOICE_AGENT_RECORDINGS_DIR=

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
LIVEKIT_AGENT_NAME=concierge-outbound-agent
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=ST_replace_with_outbound_trunk_id
LIVEKIT_SIP_FROM_NUMBER=+15551234567
LIVEKIT_SIP_KRISP_ENABLED=true

# Worker runtime selection
VOICE_AGENT_MODEL_PROVIDER=openai-realtime

# OpenAI Realtime
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_REALTIME_MODEL=
OPENAI_REALTIME_VOICE=cedar
OPENAI_REALTIME_TURN_THRESHOLD=0.82
OPENAI_REALTIME_TURN_PREFIX_PADDING_MS=700
OPENAI_REALTIME_TURN_SILENCE_DURATION_MS=1200
OPENAI_REALTIME_INPUT_AUDIO_NOISE_REDUCTION=far_field

# Gemini Live
GOOGLE_API_KEY=replace-with-google-api-key
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_LIVE_VOICE=Puck

# Optional pipeline fallback overrides
LIVEKIT_STT_MODEL=assemblyai/universal-streaming:en
LIVEKIT_LLM_MODEL=openai/gpt-4.1-mini
LIVEKIT_TTS_MODEL=cartesia/sonic-2:9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
