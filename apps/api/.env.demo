# Demo Mode Configuration
# Copy this to .env to run in demo mode
# Only GEMINI_API_KEY is required (for provider search and call simulation)

PORT=8000
NODE_ENV=development
DEMO_MODE=true
CORS_ORIGIN=http://localhost:3000

# Only real API key needed - Gemini powers search and simulated calls
GEMINI_API_KEY=your-gemini-api-key-here

# These are NOT needed in demo mode (but won't cause errors if present)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# VAPI_API_KEY=
# VAPI_PHONE_NUMBER_ID=
