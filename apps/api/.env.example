# Server Configuration
PORT=8000
NODE_ENV=development

# Structured logging level (fatal|error|warn|info|debug|trace). Default: info.
# JSON logs are emitted when NODE_ENV=production; pretty logs otherwise. Every
# log line carries a `reqId`; the same id is returned in the x-request-id header.
LOG_LEVEL=info

# Public base URL of THIS API as seen by external callers (proxies, Twilio,
# VAPI). Used to reconstruct the exact URL a webhook was signed against. When
# unset, the signer derives it from x-forwarded-proto / x-forwarded-host.
# Example: https://api.yourdomain.com
PUBLIC_BASE_URL=

# Optional error monitoring (Sentry). Fully opt-in: only active when SENTRY_DSN
# is set AND @sentry/node is installed (`pnpm --filter api add @sentry/node`).
# The API builds and runs identically without it.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0

# Per-organization dispatch rate limiting (token bucket, in-memory).
# DISPATCH_RATE_LIMIT_PER_MINUTE: sustained calls to /api/v1/dispatch/* per org.
# DISPATCH_RATE_LIMIT_BURST: burst capacity (defaults to the per-minute value).
DISPATCH_RATE_LIMIT_PER_MINUTE=30
DISPATCH_RATE_LIMIT_BURST=30

# Public URLs (used in generated links / notifications). Optional.
API_URL=http://localhost:8000
APP_URL=http://localhost:3000

# Demo Mode - runs without Supabase or VAPI
# When true: Uses Gemini simulated calls, skips database, skips auth
# Perfect for demos and presentations without infrastructure dependencies
DEMO_MODE=false

# Public marketing demo-call endpoint (POST /api/v1/demo-call), DEFAULT: disabled.
# The landing page lets a logged-out visitor request a one-time, consented,
# recorded demo call to their own number. It stays OFF (and never dials) unless
# this is the exact string "true" AND Retell telephony is configured
# (RETELL_API_KEY + RETELL_FROM_NUMBER). While off, the endpoint returns a
# graceful "unavailable" response instead of placing a call. When on, calls are
# rate-limited to one per number per 24h plus a per-IP ceiling.
DEMO_CALL_ENABLED=false

# Research-and-Book feature flag (DEFAULT: disabled).
# The legacy Research-and-Book flow (POST /providers/call, /providers/batch-call,
# /providers/batch-call-async, /providers/book, and the Twilio SMS auto-book
# trigger) places REAL outbound calls with the compliance gate and org context
# bypassed. It is disabled for v1. Set to the exact string "true" to enable;
# any other value (or unset) leaves it OFF and those routes return 403.
ENABLE_RESEARCH_AND_BOOK=false

# CORS Configuration
# Comma-separated for multiple origins (e.g., https://app.com,https://preview.app.com)
# For production, add: https://concierge-ai-web.vercel.app
CORS_ORIGIN=http://localhost:3000,https://concierge-ai-web.vercel.app

# Supabase Configuration
# Get these values from your Supabase project settings: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# WARNING: The SERVICE_ROLE_KEY bypasses Row Level Security (RLS)
# Keep it secure and never expose it in client-side code
# Only use this key in trusted backend environments

# JWT Secret for verifying Supabase auth tokens
# Get this from: Supabase Dashboard > Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Authentication Configuration
# Set to "false" to bypass authentication in development (uses dev user)
# In production, always set to "true" or omit
REQUIRE_AUTH=true

# Development User (used when REQUIRE_AUTH=false)
DEV_USER_ID=dev-user-id
DEV_USER_EMAIL=dev@example.com
DEV_USER_NAME=Dev User

# Stripe Billing Configuration (Optional - billing routes return 503 without it)
# STRIPE_SECRET_KEY: Stripe Dashboard > Developers > API keys
# STRIPE_WEBHOOK_SECRET: Stripe Dashboard > Developers > Webhooks (per endpoint)
# STRIPE_PRICE_STARTER / STRIPE_PRICE_PRO: price ids for the placeholder plans
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Google Gemini AI Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Google Places API Configuration
# Get your API key from: Google Cloud Console > APIs & Services > Credentials
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# Brave Search API Configuration (Optional - enables web reputation enrichment)
# Used after Places discovery to find Yelp, BBB, Facebook, Thumbtack, Houzz, and other public reputation pages
# Get your API key from: https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# Call Backend Selection
# Pluggable outbound-call telephony backend (see CLAUDE.md "CallBackend")
# Options:
#   livekit (default) : LiveKit-backed ContractorCallService adapter
#   retell            : Retell AI (see Retell config below)
#   vapi              : wraps the VAPI REST API (uses the VAPI_* vars below)
#   mock              : deterministic in-memory backend for tests/demos
CALL_BACKEND=livekit

# Retell AI Configuration (required when CALL_BACKEND=retell)
# Get your API key from: https://dashboard.retellai.com > API Keys
RETELL_API_KEY=your-retell-api-key-here
# Outbound caller id: an E.164 US number owned by your Retell account
RETELL_FROM_NUMBER=+18645550100
# Existing agent to dispatch with. Leave empty to auto-provision an agent
# (looked up / created idempotently by RETELL_AGENT_NAME on first dispatch)
RETELL_AGENT_ID=
RETELL_LLM_ID=
RETELL_AGENT_NAME=concierge-outbound-caller
RETELL_VOICE_ID=11labs-Adrian
# Optional: E.164 destination for warm transfer hand-offs. When set, the
# auto-provisioned agent gets a transfer_call tool in warm_transfer mode
RETELL_TRANSFER_NUMBER=
# Local directory for call artifacts when DEMO_MODE=true or Supabase is
# unavailable (default: ./.call-artifacts). Production uses the private
# Supabase storage bucket "call-artifacts".
RETELL_ARTIFACTS_DIR=

# VAPI Voice AI Configuration
# Get these values from: https://dashboard.vapi.ai
# VAPI_API_KEY: Found in Account Settings > API Keys
# VAPI_PHONE_NUMBER_ID: Found in Phone Numbers > Select your number > Copy ID
# Required for the Research-and-Book VAPI pipeline, and for CALL_BACKEND=vapi
VAPI_API_KEY=your-vapi-api-key-here
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id-here

# VAPI Webhook Configuration (Optional - enables hybrid mode)
# When set: DirectVapiClient uses webhooks + cache polling (fast, auto-persistence to DB)
# When not set: DirectVapiClient uses direct VAPI polling (works everywhere)
# For local dev: Use ngrok URL (e.g., https://your-id.ngrok-free.app/api/v1/vapi/webhook)
# For production: Use your deployed backend URL (e.g., https://api.yourdomain.com/api/v1/vapi/webhook)
VAPI_WEBHOOK_URL=

# VAPI webhook shared secret (REQUIRED in production to authenticate inbound
# webhooks). Configure the same value as a server-auth header (X-Vapi-Secret)
# in the VAPI dashboard. When set, the webhook rejects requests without a
# matching header; when unset, verification is skipped (dev only).
VAPI_WEBHOOK_SECRET=

# Backend URL for webhook result polling (used by DirectVapiClient)
# Default: http://localhost:8000
BACKEND_URL=http://localhost:8000

# VAPI Concurrent Call Configuration
VAPI_MAX_CONCURRENT_CALLS=5

# VAPI OpenAI Realtime Configuration (Optional - enables natural voice)
# When VAPI_USE_REALTIME=true: Uses OpenAI GPT-4o Realtime for native speech-to-speech
#   - ~50% lower latency (300-700ms vs 800-1200ms)
#   - Natural voice with emotional intelligence
#   - No separate STT/TTS pipeline
# When VAPI_USE_REALTIME=false (default): Uses traditional Gemini + Deepgram + ElevenLabs
VAPI_USE_REALTIME=false

# OpenAI Realtime voice selection (only used when VAPI_USE_REALTIME=true)
# Options: alloy, echo, shimmer, marin (professional), cedar (conversational)
# Default: marin (recommended for business calls)
VAPI_REALTIME_VOICE=marin

# Kestra Workflow Orchestration Configuration
# ============================================

# Master toggle - set to true to use Kestra, false for direct VAPI/Gemini calls
KESTRA_ENABLED=false

# Mode: "local" or "cloud" - determines which Kestra instance to use
# Change this single variable to switch between local and cloud Kestra
KESTRA_MODE=local

# Local Kestra Configuration (used when KESTRA_MODE=local)
KESTRA_LOCAL_URL=http://localhost:8082

# Kestra Cloud Configuration (used when KESTRA_MODE=cloud)
# Get these from your Kestra Cloud dashboard
KESTRA_CLOUD_URL=https://your-instance.kestra.cloud
KESTRA_CLOUD_TENANT=main
KESTRA_API_TOKEN=your-kestra-api-token-here

# Shared Configuration (used in both modes)
KESTRA_NAMESPACE=ai_concierge
KESTRA_HEALTH_CHECK_TIMEOUT=3000

# Twilio SMS / Voice Configuration
# ============================================
# Used for inbound-SMS provider selection, outbound notification SMS, and the
# LiveKit SIP voice path. TWILIO_AUTH_TOKEN also verifies inbound webhook
# signatures (X-Twilio-Signature); when set, unsigned webhooks are rejected.
# The Account SID must start with "AC" (not an API-key "SK" prefix).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
# Sending number for SMS (E.164). TWILIO_PHONE_NO is a legacy alias.
TWILIO_PHONE_NUMBER=+18005550100
TWILIO_PHONE_NO=+18005550100
# Optional dedicated outbound-voice caller id (falls back to TWILIO_PHONE_NUMBER)
TWILIO_VOICE_PHONE_NUMBER=

# Admin test phone override: when set, outbound provider calls are redirected to
# these comma-separated E.164 numbers instead of the real provider (safe demos).
ADMIN_TEST_NUMBER=

# Google Maps API key (optional; distinct from GOOGLE_PLACES_API_KEY). Used by
# grounding/geocoding paths that call the Maps API directly.
GOOGLE_MAPS_API_KEY=

# Retell REST base URL override (optional; defaults to https://api.retellai.com).
RETELL_API_BASE_URL=

# ============================================
# LiveKit Voice Agent (CALL_BACKEND=livekit, the default)
# ============================================
# Master runtime selector consumed by the legacy runtime-router. Keep aligned
# with CALL_BACKEND: "livekit" (default) or "vapi".
CALL_RUNTIME_PROVIDER=livekit
# Feature flag surfaced to the web app for enabling real (non-simulated) calls.
LIVE_CALL_ENABLED=false

# LiveKit Cloud / self-hosted connection (required when CALL_BACKEND=livekit)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_AGENT_NAME=concierge-voice-agent
# LiveKit SIP outbound (for real PSTN dialing via a configured SIP trunk)
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
LIVEKIT_SIP_FROM_NUMBER=
LIVEKIT_SIP_KRISP_ENABLED=true

# Shared secret between the API and the voice-agent service. The voice-agent
# authenticates its tool calls to /api/v1/voice-tools with this value.
VOICE_AGENT_SHARED_SECRET=change-me-shared-secret
# Internal service URLs the API uses to reach the voice-agent worker.
VOICE_AGENT_SERVICE_URL=http://localhost:8090
VOICE_AGENT_WORKER_CONTROL_URL=http://localhost:8091
