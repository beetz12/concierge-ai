{
  "name": "concierge-ai",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NexAiAdvisors/concierge-ai"
  },
  "keywords": [
    "ai",
    "voice-ai",
    "receptionist",
    "vapi",
    "nextjs",
    "fastify"
  ],
  "author": "Team NexAI",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "launchd:install": "./scripts/launchd/install.sh",
    "mcp:voice": "pnpm --filter voice-mcp start",
    "test:e2e": "playwright test",
    "test:smoke:provider-intel": "pnpm --filter api exec tsx scripts/provider-intel-smoke.ts",
    "test:verify": "pnpm --filter api test && pnpm --filter api check-types && pnpm --filter api build && pnpm --filter web check-types && pnpm --filter web build && pnpm test:e2e",
    "prepare": "husky",
    "cline:security": "./scripts/cline/security-review.sh --staged",
    "cline:review": "./scripts/cline/code-review.sh --staged",
    "cline:workflow": "./scripts/cline/workflow-guardian.sh --all",
    "cline:adapter": "./scripts/cline/generate-adapter.sh",
    "cline:test": "./scripts/cline/generate-tests.sh",
    "cline:docs": "./scripts/cline/update-docs.sh --all",
    "cline:setup": "./scripts/setup-husky.sh",
    "migrate:workflow": "node kestra/scripts/deploy-flows.js",
    "migrate:workflow:dry": "node kestra/scripts/deploy-flows.js --dry-run",
    "migrate:workflow-vars": "node kestra/scripts/migrate-envs-to-secrets.js",
    "migrate:workflow-vars:dry": "node kestra/scripts/migrate-envs-to-secrets.js --dry-run"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "baseline-browser-mapping": "^2.10.0",
    "husky": "^9.0.11",
    "prettier": "^3.6.2",
    "turbo": "^2.6.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18"
  }
}
